# Neon Postgres pooled connection string (use the -pooler host for serverless functions)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/ark_plantain_mundy?sslmode=require"

# Direct (non-pooled) connection, used by Prisma Migrate
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/ark_plantain_mundy?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
NODE_ENV="development"

# Phase 1 calculation defaults (open items from architecture doc §10 — confirm with business)
DEFAULT_COMMISSION_PERCENT="5"
BILL_NUMBERING_MODE="daily-reset"
DEFAULT_BILL_LANGUAGE="EN"

# Local dev only
API_PORT="4000"
VITE_API_BASE_URL="http://localhost:4000/api"
